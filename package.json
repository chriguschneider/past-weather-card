{
  "name": "weather-station-card",
  "version": "1.3.0",
  "description": "Lovelace card showing past weather-station measurements with the weather-chart-card layout, plus live current-condition rendering driven by sensor history.",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "lovelace",
    "custom-cards",
    "weather",
    "weather-station",
    "sensor",
    "history",
    "statistics",
    "chart"
  ],
  "main": "dist/weather-station-card.js",
  "module": "src/main.ts",
  "homepage": "https://github.com/chriguschneider/weather-station-card",
  "bugs": {
    "url": "https://github.com/chriguschneider/weather-station-card/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chriguschneider/weather-station-card.git"
  },
  "author": "chrigu",
  "contributors": [
    "Marc Lamberts (original weather-chart-card author)"
  ],
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.4.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "lit": "^2.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chart.js": "^2.9.41",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.56.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "rollup": "^4.9.6",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-serve": "^2.0.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "start": "rollup -c rollup.config.dev.js --watch",
    "build": "npm run typecheck && npm run test && npm run rollup",
    "lint": "echo \"ESLint disabled — all sources are TypeScript; tsc covers compile-time checks (v1.2)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "rollup": "rollup -c",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  }
}
