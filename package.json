  "contributors": [
    "Marc Lamberts (original weather-chart-card author)"
  ],
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.4.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "lit": "^2.8.0",
    "relative-time": "^1.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "rollup": "^4.9.6",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-serve": "^2.0.3"
  },
  "scripts": {
